# ---- Base image ----
FROM node:23-alpine

# ---- Set working directory ----
WORKDIR /app

# ---- Install JSON Server globally inside this container ----
RUN npm install -g json-server@0.17.4

# ---- Copy only what JSON Server actually needs ----
COPY db.json json-server.json ./

# ---- Expose JSON Server's port ----
EXPOSE 3001

# ---- Start JSON Server, accessible outside the container ----
CMD ["json-server", "--watch", "db.json", "--host", "0.0.0.0", "--port", "3001"]