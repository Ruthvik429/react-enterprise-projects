      "title": "Creamy Garlic Butter Tuscan Shrimp",
      "image": "https://images.unsplash.com/photo-1547592166-23ac45744acd?w=600",
      "cuisine": "Italian",
      "difficulty": "Easy",
      "cookTimeMinutes": 25,
      "servings": 4,
      "rating": 4.8,
      "ingredients": [
        "1 lb large shrimp, peeled and deveined",
        "3 tbsp butter",
        "5 cloves garlic, minced",
        "1 cup heavy cream",
        "1/2 cup sun-dried tomatoes, chopped",
        "1 cup baby spinach",
        "1/2 cup parmesan cheese, grated",
        "Salt and pepper to taste"
      ],
      "steps": [
        "Season shrimp with salt and pepper.",
        "Melt butter in a skillet over medium heat, cook shrimp 2 min per side, remove.",
        "In the same skillet, saute garlic until fragrant.",
        "Add cream, sun-dried tomatoes, and simmer 3 minutes.",
        "Stir in parmesan and spinach until wilted.",
        "Return shrimp to the skillet, coat in sauce, serve hot."
      ],
      "nutrition": {
        "calories": 420,
        "protein": 32,
        "carbs": 8,
        "fat": 29
      }
    },
